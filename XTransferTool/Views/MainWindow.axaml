<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:XTransferTool.ViewModels"
        xmlns:views="using:XTransferTool.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="XTransferTool.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="X传输工具"
        MinWidth="980"
        MinHeight="640">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto" ColumnDefinitions="260,*" Background="{DynamicResource AppBackgroundBrush}">
        <!-- Sidebar -->
        <Border Grid.RowSpan="2" Background="{DynamicResource SidebarBackgroundBrush}">
            <Grid RowDefinitions="Auto,*,Auto" Margin="16,18,12,16">
                <StackPanel Spacing="10">
                    <TextBlock Text="X传输工具" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding IdentitySummary}" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}"/>
                </StackPanel>

                <ListBox Grid.Row="1"
                         Margin="0,18,0,0"
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavItem}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:NavItem">
                            <Border CornerRadius="12"
                                    Padding="12,10"
                                    Margin="0,0,0,10"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource CardBackgroundBrush}">
                                <Grid ColumnDefinitions="28,*" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding IconGlyph}"
                                               FontSize="16"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2" Height="0" IsHitTestVisible="False" Opacity="0"/>
            </Grid>
        </Border>

        <!-- Main content -->
        <Border Grid.Column="1"
                Margin="18,18,18,10"
                CornerRadius="18"
                Background="{DynamicResource MainPanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1">
            <ContentControl Content="{Binding CurrentPage}" Margin="16">
                <!-- Explicit templates so each page's DataContext is the view model (not MainWindowViewModel). -->
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:HomeViewModel">
                        <views:HomeView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:InboxViewModel">
                        <views:InboxView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:RemoteDesktopViewModel">
                        <views:RemoteDesktopView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:SettingsViewModel">
                        <views:SettingsView />
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Height="0" IsHitTestVisible="False" Opacity="0"/>
    </Grid>

</Window>
